@startuml Final

class UsuarioLogin {
    -Nombre: String
    -Contraseña: String

    -Logueo(): void
    -CerrarSesion(): void

}

class Administrador {
    -Id: int

    -GestionarClubes(): void
    -GestionarJugadores(): void
    -GestionarFixtures(): void
    -SubirBoletin(): void
    -GestionarSanción(): void
    -ResultadoPartido(): void

}

class Club {
    -NombrePresidente: String
    -NombreEntrenador: String
    -NombresJugadores: String
    -Categoria: String

    -VerFixture(): void
    -SuberCarnet(): void
    -AccederCarnetOtroEquipo(): void
    -ImprimirFormulario(): void
    -VerBoletin(): void
}

class Jugador {
    -Nombre: String
    -Apellido: String
    -Cedula: String
    -FechaNacimiento: Date

    -RecuentoTarjetas(): int  
}

class Partido {
    -FechaPartido: Date
    -HoraPartido: String
    -DuracionPartido: String
    -ClubLocal: String
    -ClubVisitante: String
    -NombreEstadio: String
    -NombreArbitro: String
}

class Sancion {
    -TipoSancion: String
    -Motivo: String
    -CantidadFechas: int
}

class CarnetAptitudFisica {
    -Vigente: Boolean
    -FechaVencimiento: Date
    -CarnetJugador: String
}

@enduml